
// FitFlow Suite - Database Schema
// Supports: FitFlow Pro (SaaS) + FitBot AI (Chatbot)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
// ============================================
// MULTI-TENANT CORE
// ============================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(STARTER)
  logoUrl   String?  @map("logo_url")
  phone     String?
  email     String?
  address   String?
  timezone  String   @default("America/Sao_Paulo")

  // Feature flags
  whatsappEnabled Boolean @default(false) @map("whatsapp_enabled")
  chatbotEnabled  Boolean @default(false) @map("chatbot_enabled")
  coinsEnabled    Boolean @default(true)  @map("coins_enabled")

  // Chatbot config
  chatbotConfig Json? @map("chatbot_config")
  // { welcomeMessage, businessHours, aiPersonality, knowledgeBase[] }

  // Billing
  stripeCustomerId     String? @map("stripe_customer_id")
  stripeSubscriptionId String? @map("stripe_subscription_id")

  // API Key (for external agent integrations like Laura/OpenClaw)
  apiKey String? @unique @map("api_key")

  // WhatsApp
  whatsappInstanceId String? @map("whatsapp_instance_id")
  whatsappNumber     String? @map("whatsapp_number")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  profiles         Profile[]
  services         Service[]
  bookings         Booking[]
  checkins         Checkin[]
  coinTransactions CoinTransaction[]
  rewards          Reward[]
  conversations    ChatConversation[]
  subscriptions    Subscription[]
  scheduleSlots    ScheduleSlot[]
  announcements    Announcement[]

  @@map("organizations")
}

enum Plan {
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

// ============================================
// USER PROFILES
// ============================================

model Profile {
  id       String @id @default(cuid())
  userId   String @unique @map("user_id") // FK to Supabase auth.users
  orgId    String @map("org_id")
  role     Role   @default(STUDENT)

  fullName  String  @map("full_name")
  email     String
  phone     String?
  avatarUrl String? @map("avatar_url")
  bio       String?

  // FitCoins
  coinsBalance Int @default(0) @map("coins_balance")

  // Student-specific
  emergencyContact String? @map("emergency_contact")
  healthNotes      String? @map("health_notes")
  birthDate        DateTime? @map("birth_date")

  // Trainer-specific
  specialties String[] @default([])
  certifications String[] @default([])
  hourlyRate  Decimal? @map("hourly_rate") @db.Decimal(10, 2)

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  organization     Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  trainerBookings  Booking[]         @relation("TrainerBookings")
  studentBookings  Booking[]         @relation("StudentBookings")
  checkins         Checkin[]
  coinTransactions CoinTransaction[]
  subscriptions    Subscription[]
  scheduleSlots    ScheduleSlot[]

  @@index([orgId])
  @@index([userId])
  @@index([role])
  @@map("profiles")
}

enum Role {
  ADMIN
  TRAINER
  STUDENT
}

// ============================================
// SERVICES & SCHEDULING
// ============================================

model Service {
  id          String @id @default(cuid())
  orgId       String @map("org_id")
  name        String
  description String?
  
  durationMinutes Int     @map("duration_minutes")
  price           Decimal @db.Decimal(10, 2)
  maxCapacity     Int     @default(1) @map("max_capacity")
  color           String  @default("#6366f1") // For UI calendar
  
  category    ServiceCategory @default(PERSONAL)
  isActive    Boolean         @default(true) @map("is_active")
  coinsReward Int             @default(1) @map("coins_reward") // Coins per check-in

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  bookings     Booking[]
  scheduleSlots ScheduleSlot[]

  @@index([orgId])
  @@map("services")
}

enum ServiceCategory {
  PERSONAL
  GROUP
  ONLINE
  EVALUATION
  OTHER
}

model ScheduleSlot {
  id        String @id @default(cuid())
  orgId     String @map("org_id")
  serviceId String @map("service_id")
  trainerId String @map("trainer_id")

  dayOfWeek Int    // 0=Sunday, 6=Saturday
  startTime String @map("start_time") // "08:00"
  endTime   String @map("end_time")   // "09:00"

  isActive Boolean @default(true) @map("is_active")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  trainer      Profile      @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([orgId, dayOfWeek])
  @@map("schedule_slots")
}

// ============================================
// BOOKINGS
// ============================================

model Booking {
  id        String @id @default(cuid())
  orgId     String @map("org_id")
  serviceId String @map("service_id")
  trainerId String @map("trainer_id")
  studentId String @map("student_id")

  startsAt DateTime @map("starts_at")
  endsAt   DateTime @map("ends_at")
  
  status BookingStatus @default(PENDING)
  source BookingSource @default(WEB)

  checkedInAt DateTime? @map("checked_in_at")
  cancelledAt DateTime? @map("cancelled_at")
  cancelReason String?  @map("cancel_reason")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  trainer      Profile      @relation("TrainerBookings", fields: [trainerId], references: [id])
  student      Profile      @relation("StudentBookings", fields: [studentId], references: [id])
  checkin      Checkin?

  @@index([orgId, startsAt])
  @@index([trainerId, startsAt])
  @@index([studentId, startsAt])
  @@index([status])
  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BookingSource {
  WEB
  WHATSAPP
  MANUAL
  RECURRING
}

// ============================================
// CHECK-IN & FITCOINS
// ============================================

model Checkin {
  id        String @id @default(cuid())
  bookingId String @unique @map("booking_id")
  studentId String @map("student_id")
  orgId     String @map("org_id")

  method      CheckinMethod @default(MANUAL)
  coinsAwarded Int           @default(0) @map("coins_awarded")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  student      Profile      @relation(fields: [studentId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@map("checkins")
}

enum CheckinMethod {
  QR_CODE
  MANUAL
  WHATSAPP
  BIOMETRIC
}

model CoinTransaction {
  id        String @id @default(cuid())
  profileId String @map("profile_id")
  orgId     String @map("org_id")

  amount      Int
  type        CoinTransactionType
  description String
  referenceId String? @map("reference_id") // booking_id, reward_id, etc.

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  profile      Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt])
  @@index([orgId])
  @@map("coin_transactions")
}

enum CoinTransactionType {
  EARNED
  SPENT
  BONUS
  REFUND
}

model Reward {
  id          String @id @default(cuid())
  orgId       String @map("org_id")
  name        String
  description String?
  costCoins   Int    @map("cost_coins")
  stock       Int?   // null = unlimited
  imageUrl    String? @map("image_url")
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("rewards")
}

// ============================================
// CHATBOT (FitBot AI)
// ============================================

model ChatConversation {
  id             String @id @default(cuid())
  orgId          String @map("org_id")
  whatsappNumber String @map("whatsapp_number")
  contactName    String? @map("contact_name")
  
  currentMode ChatMode @default(ATTENDANCE) @map("current_mode")
  contextData Json?    @map("context_data") @db.JsonB
  // { lastIntent, collectedData, currentStep, history[] }

  isActive      Boolean  @default(true) @map("is_active")
  lastMessageAt DateTime @default(now()) @map("last_message_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]

  @@unique([orgId, whatsappNumber])
  @@index([orgId, isActive])
  @@index([lastMessageAt])
  @@map("chat_conversations")
}

enum ChatMode {
  ATTENDANCE
  SCHEDULING
  SALES
  HUMAN_HANDOFF
}

model ChatMessage {
  id             String @id @default(cuid())
  conversationId String @map("conversation_id")
  orgId          String @map("org_id")

  direction   MessageDirection
  content     String
  messageType MessageType @default(TEXT) @map("message_type")
  
  aiGenerated Boolean @default(false) @map("ai_generated")
  aiModel     String? @map("ai_model")
  tokensUsed  Int?    @map("tokens_used")

  metadata Json? @db.JsonB
  // { whatsappMessageId, mediaUrl, buttons[], sentiment }

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([orgId, createdAt])
  @@map("chat_messages")
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  LOCATION
  CONTACT
  BUTTON_REPLY
  LIST_REPLY
}

// ============================================
// BILLING & SUBSCRIPTIONS
// ============================================

model Subscription {
  id        String @id @default(cuid())
  orgId     String @map("org_id")
  studentId String @map("student_id")

  planName String  @map("plan_name")
  price    Decimal @db.Decimal(10, 2)
  interval SubscriptionInterval @default(MONTHLY)

  stripeSubscriptionId String? @map("stripe_subscription_id")
  stripePaymentIntent  String? @map("stripe_payment_intent")

  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime @map("current_period_start")
  currentPeriodEnd   DateTime @map("current_period_end")

  cancelledAt DateTime? @map("cancelled_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  student      Profile      @relation(fields: [studentId], references: [id])

  @@index([orgId])
  @@index([studentId])
  @@index([status])
  @@map("subscriptions")
}

enum SubscriptionInterval {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
  TRIAL
}

// ============================================
// ANNOUNCEMENTS / NOTIFICATIONS
// ============================================

model Announcement {
  id      String @id @default(cuid())
  orgId   String @map("org_id")
  title   String
  content String
  
  targetRole Role? @map("target_role") // null = all
  isPinned   Boolean @default(false) @map("is_pinned")
  
  publishAt DateTime @default(now()) @map("publish_at")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, publishAt])
  @@map("announcements")
}
